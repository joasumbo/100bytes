<!DOCTYPE html>
<html lang="pt-PT">
<%
const __pageTitle = (typeof pageTitle !== 'undefined') ? pageTitle : '';
const __category = (typeof category !== 'undefined') ? category : null;
const __pagination = (typeof pagination !== 'undefined') ? pagination : null;
const __currentFilters = (typeof currentFilters !== 'undefined' && currentFilters) ? currentFilters : {};
const __products = (typeof products !== 'undefined' && products) ? products : [];
const __categories = (typeof categories !== 'undefined' && categories) ? categories : [];
const __brands = (typeof brands !== 'undefined' && brands) ? brands : [];
const __topProducts = (typeof topProducts !== 'undefined' && topProducts) ? topProducts : [];
const __heading = __pageTitle || (__category ? __category.name : 'Produtos');
%>
<head>
    <title><%= __heading %> | 100bytes</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <link rel="shortcut icon" href="https://cdn100ka.sysvenus.com/logo/100byte_fav.png">
    <link rel="icon" type="image/png" href="https://cdn100ka.sysvenus.com/logo/100byte_fav.png">

    <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,300i,400,400i,600,600i,700,700i,800,800i&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/assets/vendor/font-awesome/css/fontawesome-all.min.css">
    <link rel="stylesheet" href="/assets/css/font-electro.css">
    <link rel="stylesheet" href="/assets/vendor/animate.css/animate.min.css">
    <link rel="stylesheet" href="/assets/vendor/hs-megamenu/src/hs.megamenu.css">
    <link rel="stylesheet" href="/assets/vendor/malihu-custom-scrollbar-plugin/jquery.mCustomScrollbar.css">
    <link rel="stylesheet" href="/assets/vendor/fancybox/jquery.fancybox.css">
    <link rel="stylesheet" href="/assets/vendor/slick-carousel/slick/slick.css">
    <link rel="stylesheet" href="/assets/vendor/bootstrap-select/dist/css/bootstrap-select.min.css">
    <link rel="stylesheet" href="/assets/css/theme.css">

    <style>
        :root {
            --brand-primary: #F57C00;
            --brand-secondary: #D96A00;
        }

        .bg-primary,
        .badge-primary,
        .u-header .btn-primary,
        .u-header .btn-primary:not(:disabled):not(.disabled):active,
        .u-header .btn-primary:not(:disabled):not(.disabled).active {
            background-color: var(--brand-primary) !important;
            border-color: var(--brand-primary) !important;
        }

        .u-header-topbar {
            background-color: #ffffff !important;
            border-bottom: 1px solid #e6e6e6;
        }

        .btn-primary,
        .btn-primary:hover,
        .btn-primary:focus,
        .btn-primary:active,
        .btn-primary:not(:disabled):not(.disabled):active,
        .btn-primary:not(:disabled):not(.disabled).active {
            background-color: var(--brand-primary) !important;
            border-color: var(--brand-primary) !important;
        }

        .btn-primary:hover,
        .btn-primary:focus,
        .btn-add-cart:hover,
        a.text-primary:hover,
        a:hover .text-primary {
            background-color: var(--brand-secondary) !important;
            border-color: var(--brand-secondary) !important;
            color: #fff !important;
        }

        .text-primary,
        .link-hover__brand:hover,
        .u-header__nav-link:hover,
        .u-header-topbar__nav-link:hover,
        .ec.ec-add-to-cart,
        .ec.ec-favorites {
            color: var(--brand-primary) !important;
        }

        .border-primary,
        .border-color-1,
        .nav-tab .nav-link.active::before,
        .nav-tab .nav-link:hover::before {
            border-color: var(--brand-primary) !important;
        }

        .u-header-topbar .topbar-left a,
        .u-header-topbar .u-header-topbar__nav-link,
        .u-header-topbar .dropdown-nav-link,
        .u-header-topbar .text-gray-50 {
            color: #2f2f33 !important;
        }

        .u-header-topbar .u-header-topbar__nav-item-border::after {
            border-color: rgba(47, 47, 51, 0.28) !important;
        }

        .u-header .form-control,
        .u-header .form-control::placeholder {
            color: #5f636b !important;
            font-weight: 600;
        }

        .bg-primary-down-lg {
            background-color: #ffffff !important;
        }

        .product-img-wrap {
            position: relative;
            display: block;
            overflow: hidden;
            height: 200px;
        }

        .product-img-wrap img {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: contain;
            transition: opacity 0.35s ease;
        }

        .product-img-primary {
            opacity: 1;
            z-index: 1;
        }

        .product-img-hover {
            opacity: 0;
            z-index: 2;
        }

        .product-img-wrap:hover .product-img-primary {
            opacity: 0;
        }

        .product-img-wrap:hover .product-img-hover {
            opacity: 1;
        }

        .products-group .product-item__body {
            display: flex;
            flex-direction: column;
        }

        .product-item__title {
            min-height: 42px;
        }

        .prodcut-add-cart {
            display: block !important;
        }

        .btn-add-cart .ec {
            color: #fff !important;
        }
    </style>
</head>
<body>

<%- include('partials/_header') %>

<main id="content" role="main" class="pt-3">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb breadcrumb-no-gutter font-size-12">
                <li class="breadcrumb-item"><a href="/">Inicio</a></li>
                <li class="breadcrumb-item active" aria-current="page"><%= __heading %></li>
            </ol>
        </nav>

        <div class="mb-4">
            <h1 class="font-size-25 mb-1"><%= __heading %></h1>
            <p class="text-gray-6 font-size-13 mb-0"><%= __pagination && __pagination.total ? __pagination.total : 0 %> produto(s) encontrado(s)</p>
        </div>

        <div class="row mb-8">
            <aside class="col-lg-3 mb-6 mb-lg-0">
                <div class="border border-color-1 rounded mb-4">
                    <div class="p-3 bg-gray-1 border-bottom"><strong class="font-size-15">Categorias</strong></div>
                    <ul class="list-unstyled mb-0 p-3">
                        <% __categories.forEach(function(cat) { %>
                        <li class="mb-2">
                            <a href="/<%= cat.slug %>" class="text-gray-90"><%= cat.name %></a>
                        </li>
                        <% }) %>
                    </ul>
                </div>

                <form method="GET" class="border border-color-1 rounded p-3">
                    <div class="mb-4">
                        <label class="font-size-14 font-weight-bold mb-2 d-block">Ordenar</label>
                        <select name="sort" class="form-control form-control-sm">
                            <option value="" <%= !__currentFilters.sort ? 'selected' : '' %>>Relevancia</option>
                            <option value="newest" <%= __currentFilters.sort === 'newest' ? 'selected' : '' %>>Mais recentes</option>
                            <option value="price_asc" <%= __currentFilters.sort === 'price_asc' ? 'selected' : '' %>>Preco: menor para maior</option>
                            <option value="price_desc" <%= __currentFilters.sort === 'price_desc' ? 'selected' : '' %>>Preco: maior para menor</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="font-size-14 font-weight-bold mb-2 d-block">Preco</label>
                        <div class="row">
                            <div class="col-6 pr-1">
                                <input type="number" min="0" name="minPrice" class="form-control form-control-sm" placeholder="Min" value="<%= __currentFilters.minPrice || '' %>">
                            </div>
                            <div class="col-6 pl-1">
                                <input type="number" min="0" name="maxPrice" class="form-control form-control-sm" placeholder="Max" value="<%= __currentFilters.maxPrice || '' %>">
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="font-size-14 font-weight-bold mb-2 d-block">Marca</label>
                        <select name="brandId" class="form-control form-control-sm">
                            <option value="">Todas as marcas</option>
                            <% __brands.forEach(function(brand) { %>
                            <option value="<%= brand.id %>" <%= __currentFilters.brandId === brand.id ? 'selected' : '' %>><%= brand.name %></option>
                            <% }) %>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-primary btn-sm btn-block">Aplicar filtros</button>
                </form>

                <% if (__topProducts.length) { %>
                <div class="border border-color-1 rounded mt-4">
                    <div class="p-3 bg-gray-1 border-bottom"><strong class="font-size-15">Mais vistos</strong></div>
                    <div class="p-3">
                        <% __topProducts.forEach(function(p) { %>
                        <div class="media mb-3">
                            <a href="/<%= p.categorySlug %>/<%= p.urlKey %>" class="d-block mr-3">
                                <img src="<%= p.image || 'https://cdn100ka.sysvenus.com/logo/logo-1752749442.jpg' %>" alt="<%= p.name %>" style="width:58px;height:58px;object-fit:cover;border:1px solid #eee;border-radius:4px;">
                            </a>
                            <div class="media-body">
                                <a href="/<%= p.categorySlug %>/<%= p.urlKey %>" class="text-gray-90 font-size-13 d-block"><%= p.name %></a>
                                <span class="font-size-14 font-weight-bold text-gray-90"><%= p.salePrice || p.basePrice %></span>
                            </div>
                        </div>
                        <% }) %>
                    </div>
                </div>
                <% } %>
            </aside>

            <section class="col-lg-9">
                <div class="row mb-3 d-flex align-items-center">
                    <div class="col-md-6 mb-2 mb-md-0 text-gray-6 font-size-13">
                        Pagina <%= (__pagination && __pagination.page) ? __pagination.page : 1 %> de <%= (__pagination && __pagination.pages) ? __pagination.pages : 1 %>
                    </div>
                </div>

                <ul class="row list-unstyled products-group no-gutters">
                    <% if (__products.length) { %>
                    <% __products.forEach(function(product) { %>
                    <li class="col-6 col-md-4 col-xl-3 product-item">
                        <div class="product-item__outer h-100">
                            <div class="product-item__inner px-xl-4 p-3">
                                <div class="product-item__body pb-xl-2">
                                        <% if (product.category) { %>
                                        <div class="mb-2"><a href="/<%= product.categorySlug || 'produto' %>" class="font-size-12 text-gray-5"><%= product.category %></a></div>
                                        <% } %>
                                        <h5 class="mb-1 product-item__title">
                                            <a href="/<%= product.categorySlug || 'produto' %>/<%= product.urlKey %>" class="text-blue font-weight-bold"><%= product.name %></a>
                                        </h5>
                                        <div class="mb-2 position-relative">
                                            <a href="/<%= product.categorySlug || 'produto' %>/<%= product.urlKey %>" class="product-img-wrap">
                                                <% if (product.image) { %>
                                                <img class="product-img-primary" src="<%= product.image %>" alt="<%= product.name %>">
                                                <img class="product-img-hover" src="<%= product.image2 || product.image %>" alt="<%= product.name %>">
                                                <% } else { %>
                                                <img class="product-img-primary" src="https://cdn100ka.sysvenus.com/logo/logo-1752749442.jpg" alt="<%= product.name %>">
                                                <% } %>
                                            </a>
                                            <% if (product.discountPct) { %><span style="position:absolute;top:8px;left:8px;background:#ffc107;color:#212529;font-size:11px;font-weight:700;padding:3px 8px;border-radius:20px;z-index:2;line-height:1.5;pointer-events:none">-<%= product.discountPct %>%</span><% } %>
                                            <% if (product.isNew) { %><span style="position:absolute;top:8px;right:8px;background:#28a745;color:#fff;font-size:10px;font-weight:700;padding:3px 7px;border-radius:20px;z-index:2;line-height:1.5;pointer-events:none">NOVO</span><% } else if (product.lowStock) { %><span style="position:absolute;top:8px;right:8px;background:#fd7e14;color:#fff;font-size:10px;font-weight:600;padding:3px 7px;border-radius:20px;z-index:2;line-height:1.5;pointer-events:none">Aproveite agora</span><% } %>
                                        </div>
                                        <div class="flex-center-between mb-1">
                                            <div class="prodcut-price">
                                                <% if (product.salePrice) { %>
                                                <div class="d-flex align-items-center flex-wrap position-relative">
                                                    <ins class="font-size-20 text-red text-decoration-none mr-2"><%= product.salePrice %></ins>
                                                    <del class="font-size-12 tex-gray-6 position-absolute bottom-100"><%= product.basePrice %></del>
                                                </div>
                                                <% } else { %>
                                                <div class="text-gray-100"><%= product.basePrice %></div>
                                                <% } %>
                                            </div>
                                            <div class="prodcut-add-cart">
                                                <a href="/<%= product.categorySlug || 'produto' %>/<%= product.urlKey %>" class="btn-add-cart btn-primary transition-3d-hover"><i class="ec ec-add-to-cart"></i></a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="product-item__footer">
                                    <div class="border-top pt-2 flex-center-between flex-wrap">
                                        <a href="/<%= product.categorySlug || 'produto' %>/<%= product.urlKey %>" class="text-gray-6 font-size-13"><i class="ec ec-favorites mr-1 font-size-15"></i> Ver produto</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </li>
                    <% }) %>
                    <% } else { %>
                    <li class="col-12">
                        <div class="alert alert-light border">Nenhum produto encontrado com os filtros selecionados.</div>
                    </li>
                    <% } %>
                </ul>

                <% if (__pagination && __pagination.pages > 1) { %>
                <nav aria-label="Paginacao" class="d-flex justify-content-center mt-2">
                    <ul class="pagination">
                        <% for (let i = 1; i <= __pagination.pages; i++) { %>
                        <li class="page-item <%= __pagination.page === i ? 'active' : '' %>">
                            <a class="page-link" href="?page=<%= i %><%= __currentFilters.sort ? '&sort=' + encodeURIComponent(__currentFilters.sort) : '' %><%= __currentFilters.minPrice ? '&minPrice=' + encodeURIComponent(__currentFilters.minPrice) : '' %><%= __currentFilters.maxPrice ? '&maxPrice=' + encodeURIComponent(__currentFilters.maxPrice) : '' %><%= __currentFilters.brandId ? '&brandId=' + encodeURIComponent(__currentFilters.brandId) : '' %>"><%= i %></a>
                        </li>
                        <% } %>
                    </ul>
                </nav>
                <% } %>
            </section>
        </div>
    </div>
</main>

<%- include('partials/_footer') %>

<script src="/assets/vendor/jquery/dist/jquery.min.js"></script>
<script src="/assets/vendor/jquery-migrate/dist/jquery-migrate.min.js"></script>
<script src="/assets/vendor/popper.js/dist/umd/popper.min.js"></script>
<script src="/assets/vendor/bootstrap/bootstrap.min.js"></script>
<script src="/assets/vendor/hs-megamenu/src/hs.megamenu.js"></script>
<script src="/assets/vendor/svg-injector/dist/svg-injector.min.js"></script>
<script src="/assets/vendor/malihu-custom-scrollbar-plugin/jquery.mCustomScrollbar.concat.min.js"></script>
<script src="/assets/vendor/slick-carousel/slick/slick.js"></script>
<script src="/assets/vendor/bootstrap-select/dist/js/bootstrap-select.min.js"></script>
<script src="/assets/js/hs.core.js"></script>
<script src="/assets/js/components/hs.header.js"></script>
<script src="/assets/js/components/hs.hamburgers.js"></script>
<script src="/assets/js/components/hs.unfold.js"></script>
<script src="/assets/js/components/hs.malihu-scrollbar.js"></script>
<script src="/assets/js/components/hs.slick-carousel.js"></script>
<script src="/assets/js/components/hs.svg-injector.js"></script>
<script src="/assets/js/components/hs.selectpicker.js"></script>
<script>
$(window).on('load', function () {
    $('.js-mega-menu').HSMegaMenu({
        event: 'hover',
        direction: 'horizontal',
        pageContainer: $('.container'),
        breakpoint: 767.98,
        hideTimeOut: 0
    });
    $.HSCore.components.HSSVGIngector.init('.js-svg-injector');
});

$(document).on('ready', function () {
    $.HSCore.components.HSHeader.init($('#header'));
    $.HSCore.components.HSHamburgers.init('.hamburger');
    $.HSCore.components.HSUnfold.init($('[data-unfold-target]'), {
        afterOpen: function () { $(this).find('input[type="search"]').focus(); }
    });
    $.HSCore.components.HSMalihuScrollBar.init($('.js-scrollbar'));
    $.HSCore.components.HSSelectPicker.init('.js-select');
});
</script>

</body>
</html>
