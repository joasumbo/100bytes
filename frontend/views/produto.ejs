        <!-- JS Plugins Init. -->
        <script>
            $(window).on('load', function () {
                // initialization of HSMegaMenu component
                $('.js-mega-menu').HSMegaMenu({
                    event: 'hover',
                    direction: 'horizontal',
                    pageContainer: $('.container'),
                    breakpoint: 767.98,
                    hideTimeOut: 0
                });

                // initialization of svg injector module
                $.HSCore.components.HSSVGIngector.init('.js-svg-injector');
            });

            $(document).on('ready', function () {
                // initialization of header
                $.HSCore.components.HSHeader.init($('#header'));

                // initialization of animation
                $.HSCore.components.HSOnScrollAnimation.init('[data-animation]');

                // initialization of unfold component
                $.HSCore.components.HSUnfold.init($('[data-unfold-target]'), {
                    afterOpen: function () {
                        $(this).find('input[type="search"]').focus();
                    }
                });

                // initialization of popups
                $.HSCore.components.HSFancyBox.init('.js-fancybox');

                // initialization of countdowns
                var countdowns = $.HSCore.components.HSCountdown.init('.js-countdown', {
                    yearsElSelector: '.js-cd-years',
                    monthsElSelector: '.js-cd-months',
                    daysElSelector: '.js-cd-days',
                    hoursElSelector: '.js-cd-hours',
                    minutesElSelector: '.js-cd-minutes',
                    secondsElSelector: '.js-cd-seconds'
                });

                // initialization of malihu scrollbar
                $.HSCore.components.HSMalihuScrollBar.init($('.js-scrollbar'));

                // initialization of forms
                $.HSCore.components.HSFocusState.init();

                // initialization of form validation
                $.HSCore.components.HSValidation.init('.js-validate', {
                    rules: {
                        confirmPassword: {
                            equalTo: '#signupPassword'
                        }
                    }
                });

                // initialization of show animations
                $.HSCore.components.HSShowAnimation.init('.js-animation-link');

                // initialization of fancybox
                $.HSCore.components.HSFancyBox.init('.js-fancybox');

                // initialization of slick carousel
                $.HSCore.components.HSSlickCarousel.init('.js-slick-carousel');

                // initialization of go to
                $.HSCore.components.HSGoTo.init('.js-go-to');

                // initialization of hamburgers
                $.HSCore.components.HSHamburgers.init('#hamburgerTrigger');

                // initialization of unfold component
                $.HSCore.components.HSUnfold.init($('[data-unfold-target]'), {
                    beforeClose: function () {
                        $('#hamburgerTrigger').removeClass('is-active');
                    },
                    afterClose: function() {
                        $('#headerSidebarList .collapse.show').collapse('hide');
                    }
                });

                $('#headerSidebarList [data-toggle="collapse"]').on('click', function (e) {
                    e.preventDefault();

                    var target = $(this).data('target');

                    if($(this).attr('aria-expanded') === "true") {
                        $(target).collapse('hide');
                    } else {
                        $(target).collapse('show');
                    }
                });

                // initialization of unfold component
                $.HSCore.components.HSUnfold.init($('[data-unfold-target]'));

                // initialization of select picker
                $.HSCore.components.HSSelectPicker.init('.js-select');

                // Converter todos os preços exibidos para Kz (sem mexer nos scripts)
                (function convertDisplayedCurrencyToKz() {
                    var walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, null, false);
                    var nodes = [];

                    while (walker.nextNode()) {
                        var n = walker.currentNode;
                        if (!n || !n.nodeValue || n.nodeValue.indexOf('$') === -1) {
                            continue;
                        }

                        var p = n.parentElement;
                        if (!p) {
                            continue;
                        }

                        var tag = p.tagName;
                        if (tag === 'SCRIPT' || tag === 'STYLE') {
                            continue;
                        }

                        nodes.push(n);
                    }

                    nodes.forEach(function (n) {
                        n.nodeValue = n.nodeValue
                            .replace(/�/g, '×')
                            .replace(/\$\s?([0-9][0-9\s.,]*)/g, function (_, value) {
                                return value.trim() + ' Kz';
                            });
                    });
                })();

                // Atualizar ano do copyright automaticamente
                (function updateCopyrightYear() {
                    var yearElement = document.getElementById('copyrightYear');
                    if (yearElement) {
                        yearElement.textContent = new Date().getFullYear();
                    }
                })();

                // Quantidade dinâmica com reflexo no preço
                (function initQty() {
                    var unitPrice = <%- JSON.stringify(product.salePrice || product.basePrice) %>;
                    // Extrai valor numérico (remove "\u00a0", espaços, "Kz", substitui vírgula por ponto)
                    function parseKz(str) {
                        return parseFloat(str.replace(/[^\d,]/g, '').replace(',', '.')) || 0;
                    }
                    function formatKz(val) {
                        return val.toLocaleString('pt-PT', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' Kz';
                    }

                    var base = parseKz(unitPrice);
                    var qty = 1;
                    var minus = document.getElementById('qtyMinus');
                    var plus  = document.getElementById('qtyPlus');
                    var input = document.getElementById('qtyInput');
                    var totalWrap = document.getElementById('totalPriceWrap');
                    var totalEl   = document.getElementById('totalPrice');

                    if (!minus || !plus || !input) return;

                    function update() {
                        input.value = qty;
                        minus.disabled = qty <= 1;
                        if (qty > 1) {
                            totalWrap.classList.remove('d-none');
                            totalEl.textContent = formatKz(base * qty);
                        } else {
                            totalWrap.classList.add('d-none');
                        }
                    }

                    minus.addEventListener('click', function() { if (qty > 1) { qty--; update(); } });
                    plus.addEventListener('click',  function() { qty++; update(); });
                    update();
                })();

                // Lightbox galeria de produto
                (function initProductLightbox() {
                    var galleryImgs = Array.from(document.querySelectorAll('.product-page-ncr .product-gallery-item img'));
                    if (!galleryImgs.length) return;

                    var lb = document.getElementById('ncrLightbox');
                    var lbImg = document.getElementById('ncrLbImg');
                    var lbThumbs = document.getElementById('ncrLbThumbs');
                    var lbClose = document.getElementById('ncrLbClose');
                    var lbPrev = document.getElementById('ncrLbPrev');
                    var lbNext = document.getElementById('ncrLbNext');
                    var current = 0;

                    var images = galleryImgs.map(function(img) {
                        return { src: img.src, alt: img.alt };
                    });

                    // Build thumbnails
                    images.forEach(function(data, i) {
                        var thumb = document.createElement('div');
                        thumb.className = 'ncr-lb-thumb' + (i === 0 ? ' active' : '');
                        var tImg = document.createElement('img');
                        tImg.src = data.src;
                        tImg.alt = data.alt;
                        tImg.loading = 'lazy';
                        thumb.appendChild(tImg);
                        thumb.addEventListener('click', function() { goTo(i); });
                        lbThumbs.appendChild(thumb);
                    });

                    function goTo(index) {
                        current = (index + images.length) % images.length;
                        lbImg.src = images[current].src;
                        lbImg.alt = images[current].alt;
                        var thumbEls = lbThumbs.querySelectorAll('.ncr-lb-thumb');
                        thumbEls.forEach(function(t, ti) {
                            t.classList.toggle('active', ti === current);
                        });
                    }

                    function openLb(index) {
                        goTo(index);
                        lb.classList.add('is-open');
                        document.body.style.overflow = 'hidden';
                    }

                    function closeLb() {
                        lb.classList.remove('is-open');
                        document.body.style.overflow = '';
                    }

                    galleryImgs.forEach(function(img, i) {
                        img.addEventListener('click', function() { openLb(i); });
                    });

                    lbClose.addEventListener('click', closeLb);
                    lbPrev.addEventListener('click', function() { goTo(current - 1); });
                    lbNext.addEventListener('click', function() { goTo(current + 1); });

                    lb.addEventListener('click', function(e) {
                        if (e.target === lb) closeLb();
                    });

                    document.addEventListener('keydown', function(e) {
                        if (!lb.classList.contains('is-open')) return;
                        if (e.key === 'Escape') closeLb();
                        if (e.key === 'ArrowLeft') goTo(current - 1);
                        if (e.key === 'ArrowRight') goTo(current + 1);
                    });
                })();

                // Carrinho em drawer lateral e botão flutuante visível no scroll
                (function initFloatingCart() {
                    var floating = document.getElementById('floatingCart');
                    var toggle = document.getElementById('floatingCartToggle');
                    var drawer = document.getElementById('cartDrawer');
                    var overlay = document.getElementById('cartDrawerOverlay');
                    var close = document.getElementById('cartDrawerClose');
                    var triggers = document.querySelectorAll('.js-cart-drawer-trigger');

                    if (!floating || !toggle || !drawer || !overlay || !close || !triggers.length) {
                        return;
                    }

                    function openDrawer() {
                        drawer.classList.add('is-open');
                        overlay.classList.add('is-open');
                        drawer.setAttribute('aria-hidden', 'false');
                        overlay.setAttribute('aria-hidden', 'false');
                        document.body.classList.add('cart-drawer-open');
                    }

                    function closeDrawer() {
                        drawer.classList.remove('is-open');
                        overlay.classList.remove('is-open');
                        drawer.setAttribute('aria-hidden', 'true');
                        overlay.setAttribute('aria-hidden', 'true');
                        document.body.classList.remove('cart-drawer-open');
                    }

                    function syncVisibility() {
                        if (window.innerWidth >= 1200 && window.scrollY > 320) {
                            floating.classList.add('is-visible');
                        } else {
                            floating.classList.remove('is-visible');
                        }
                    }

                    window.addEventListener('scroll', syncVisibility);
                    window.addEventListener('resize', syncVisibility);
                    syncVisibility();

                    triggers.forEach(function (trigger) {
                        trigger.addEventListener('click', function (e) {
                            e.preventDefault();
                            openDrawer();
                        });
                    });

                    close.addEventListener('click', function () {
                        closeDrawer();
                    });

                    overlay.addEventListener('click', function () {
                        closeDrawer();
                    });

                    document.addEventListener('keydown', function (e) {
                        if (e.key === 'Escape' && drawer.classList.contains('is-open')) {
                            closeDrawer();
                        }
                    });
                })();
            });
        </script>

        <!-- Sticky bar + carousel relacionados -->
        <script>
            function abrirModalLoja(e) {
                e.preventDefault();
                var m = document.getElementById('modalDisponibilidadeLoja');
                if (m) { m.style.display = 'flex'; document.body.style.overflow = 'hidden'; }
            }
            function fecharModal(id) {
                var m = document.getElementById(id);
                if (m) { m.style.display = 'none'; document.body.style.overflow = ''; }
            }
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    fecharModal('modalDisponibilidadeLoja');
                }
            });

            function nativeShare(e) {
                e.preventDefault();
                if (navigator.share) {
                    navigator.share({
                        title: '<%= product.name.replace(/'/g, "\\'") %>',
                        text: '<%= (product.salePrice || product.basePrice || '').replace(/'/g, "\\'") %>',
                        url: window.location.href
                    }).catch(function() {});
                } else {
                    navigator.clipboard.writeText(window.location.href).then(function() {
                        alert('Link copiado para a área de transferência!');
                    }).catch(function() {
                        prompt('Copie o link:', window.location.href);
                    });
                }
            }
            (function () {
                var bar = document.getElementById('ncrStickyBar');
                var trigger = document.querySelector('.ncr-product-box') || document.querySelector('.product-gallery-grid');
                function onScroll() {
                    if (!bar || !trigger) return;
                    var rect = trigger.getBoundingClientRect();
                    if (rect.bottom < 60) bar.classList.add('is-visible');
                    else bar.classList.remove('is-visible');
                }
                window.addEventListener('scroll', onScroll, { passive: true });
                onScroll();

                if (window.jQuery && jQuery.fn.slick) {
                    jQuery('.ncr-discover-slider').slick({
                        slidesToShow: 5,
                        slidesToScroll: 1,
                        arrows: true,
                        dots: false,
                        infinite: false,
                        responsive: [
                            { breakpoint: 1200, settings: { slidesToShow: 4 } },
                            { breakpoint: 992,  settings: { slidesToShow: 3 } },
                            { breakpoint: 768,  settings: { slidesToShow: 2 } },
                            { breakpoint: 576,  settings: { slidesToShow: 1 } }
                        ]
                    });
                }

                // Stock por loja — carrega ao abrir o accordion
                (function () {
                    var productId = '<%= product.id %>';
                    var loaded = false;
                    var toggle = document.getElementById('stockAccordionToggle');
                    if (!toggle) return;
                    toggle.addEventListener('click', function () {
                        if (loaded) return;
                        loaded = true;
                        fetch('/api/stores/availability/' + productId)
                            .then(function (r) { return r.json(); })
                            .then(function (data) {
                                var loading = document.getElementById('storeStockLoading');
                                var list = document.getElementById('storeStockList');
                                if (!list) return;
                                if (loading) loading.style.display = 'none';
                                var stores = data.stores || [];
                                if (stores.length === 0) {
                                    list.innerHTML = '<p class="text-muted font-size-13 mb-0">Produto sem stock disponível nas lojas físicas.</p>';
                                } else {
                                    var html = stores.map(function (s) {
                                        return '<div class="d-flex align-items-start py-2 border-bottom">' +
                                            '<div class="mr-3 mt-1"><i class="fas fa-map-marker-alt text-orange"></i></div>' +
                                            '<div class="flex-grow-1">' +
                                                '<div class="font-weight-bold font-size-13">' + s.name + '</div>' +
                                                '<div class="text-muted font-size-12">' + s.address + '</div>' +
                                                (s.phone ? '<div class="font-size-12"><a href="tel:' + s.phone + '" class="text-reset">' + s.phone + '</a></div>' : '') +
                                            '</div>' +
                                            '<div class="ml-3 text-nowrap"><span class="badge badge-success font-size-11">' + s.quantity + ' em stock</span></div>' +
                                            '</div>';
                                    }).join('');
                                    list.innerHTML = html;
                                }
                                list.style.display = '';
                            })
                            .catch(function () {
                                var loading = document.getElementById('storeStockLoading');
                                if (loading) loading.textContent = 'Não foi possível carregar a disponibilidade.';
                            });
                    });
                })();
            })();
        </script>

        <!-- Modal: Ver disponibilidade na loja -->
        <div id="modalDisponibilidadeLoja" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.5);align-items:center;justify-content:center;padding:16px">
            <div style="background:#fff;border-radius:8px;width:100%;max-width:520px;max-height:90vh;overflow-y:auto;position:relative">
                <div style="display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid #eee">
                    <span style="font-size:16px;font-weight:700">Levanta na loja em 15 minutos</span>
                    <button onclick="fecharModal('modalDisponibilidadeLoja')" style="background:none;border:none;font-size:14px;font-weight:600;cursor:pointer;color:#444;display:flex;align-items:center;gap:6px">FECHAR &times;</button>
                </div>
                <div style="padding:20px">
                    <div style="display:flex;align-items:center;gap:14px;padding-bottom:16px;border-bottom:1px solid #eee;margin-bottom:20px">
                        <% if (product.image) { %>
                        <img src="<%= product.image %>" alt="<%= product.name %>" style="width:80px;height:80px;object-fit:contain;border:1px solid #eee;border-radius:6px;flex-shrink:0">
                        <% } %>
                        <span style="font-size:14px;font-weight:600;line-height:1.4"><%= product.name %></span>
                    </div>
                    <div id="modalLojaStockList">
                        <p class="text-muted font-size-13">A carregar lojas disponíveis...</p>
                    </div>
                </div>
            </div>
        </div>



        <script>
            // Carregar lojas no modal ao abrir
            (function () {
                var loaded = false;
                var origAbrirModalLoja = window.abrirModalLoja;
                window.abrirModalLoja = function (e) {
                    origAbrirModalLoja(e);
                    if (loaded) return;
                    loaded = true;
                    var productId = '<%= product.id %>';
                    fetch('/api/stores/availability/' + productId)
                        .then(function (r) { return r.json(); })
                        .then(function (data) {
                            var list = document.getElementById('modalLojaStockList');
                            if (!list) return;
                            var stores = data.stores || [];
                            if (stores.length === 0) {
                                list.innerHTML = '<p style="color:#888;font-size:13px">Produto sem stock disponível nas lojas físicas.</p>';
                            } else {
                                list.innerHTML = stores.map(function (s) {
                                    return '<div style="display:flex;align-items:flex-start;gap:12px;padding:12px 0;border-bottom:1px solid #f0f0f0">' +
                                        '<i class="fas fa-map-marker-alt" style="color:#e77728;margin-top:3px;flex-shrink:0"></i>' +
                                        '<div style="flex:1">' +
                                            '<div style="font-weight:600;font-size:13px">' + s.name + '</div>' +
                                            '<div style="color:#888;font-size:12px">' + s.address + '</div>' +
                                            (s.phone ? '<div style="font-size:12px"><a href="tel:' + s.phone + '" style="color:#444">' + s.phone + '</a></div>' : '') +
                                        '</div>' +
                                        '<span style="background:#28a745;color:#fff;font-size:11px;padding:3px 8px;border-radius:20px;white-space:nowrap">' + s.quantity + ' em stock</span>' +
                                        '</div>';
                                }).join('');
                            }
                        })
                        .catch(function () {
                            var list = document.getElementById('modalLojaStockList');
                            if (list) list.innerHTML = '<p style="color:#888;font-size:13px">Não foi possível carregar a disponibilidade.</p>';
                        });
                };
            })();
        </script>
        <script>
            // Guardar produto nos "vistos recentemente" (localStorage)
            (function () {
                try {
                    var item = {
                        id: '<%= product.id %>',
                        slug: '<%= product.slug %>',
                        urlKey: '<%= product.urlKey %>',
                        name: <%- JSON.stringify(product.name) %>,
                        image: <%- JSON.stringify(product.image || '') %>,
                        category: <%- JSON.stringify(product.category || '') %>,
                        categorySlug: <%- JSON.stringify(product.categorySlug || '') %>,
                        basePrice: <%- JSON.stringify(product.basePrice || '') %>,
                        salePrice: <%- JSON.stringify(product.salePrice || null) %>,
                        ts: Date.now()
                    };
                    var key = 'recently_viewed';
                    var list = JSON.parse(localStorage.getItem(key) || '[]');
                    list = list.filter(function (p) { return p.id !== item.id; });
                    list.unshift(item);
                    if (list.length > 12) list = list.slice(0, 12);
                    localStorage.setItem(key, JSON.stringify(list));
                } catch (e) {}
            })();
        </script>
    </body>
</html>





