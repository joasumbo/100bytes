<!DOCTYPE html>
<html lang="pt-PT">
    <head>
        <!-- Title -->
        <title><%= product.name %> | 100bytes</title>

        <!-- Required Meta Tags Always Come First -->
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

        <!-- Favicon -->
        <link rel="shortcut icon" href="https://cdn100ka.sysvenus.com/logo/100byte_fav.png">
        <link rel="icon" type="image/png" href="https://cdn100ka.sysvenus.com/logo/100byte_fav.png">

        <!-- Google Fonts -->
        <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,300i,400,400i,600,600i,700,700i,800,800i&display=swap" rel="stylesheet">

        <!-- CSS Implementing Plugins -->
        <link rel="stylesheet" href="/assets/vendor/font-awesome/css/fontawesome-all.min.css">
        <link rel="stylesheet" href="/assets/css/font-electro.css">

        <link rel="stylesheet" href="/assets/vendor/animate.css/animate.min.css">
        <link rel="stylesheet" href="/assets/vendor/hs-megamenu/src/hs.megamenu.css">
        <link rel="stylesheet" href="/assets/vendor/malihu-custom-scrollbar-plugin/jquery.mCustomScrollbar.css">
        <link rel="stylesheet" href="/assets/vendor/fancybox/jquery.fancybox.css">
        <link rel="stylesheet" href="/assets/vendor/slick-carousel/slick/slick.css">
        <link rel="stylesheet" href="/assets/vendor/bootstrap-select/dist/css/bootstrap-select.min.css">

        <!-- CSS Electro Template -->
        <link rel="stylesheet" href="/assets/css/theme.css">

        <style>
            :root {
                --brand-primary: #F57C00;
                --brand-secondary: #D96A00;
            }

            .bg-primary,
            .badge-primary,
            .u-header .btn-primary,
            .u-header .btn-primary:not(:disabled):not(.disabled):active,
            .u-header .btn-primary:not(:disabled):not(.disabled).active {
                background-color: var(--brand-primary) !important;
                border-color: var(--brand-primary) !important;
            }

            .u-header-topbar {
                background-color: #ffffff !important;
                border-bottom: 1px solid #e6e6e6;
            }

            .btn-primary,
            .btn-primary:hover,
            .btn-primary:focus,
            .btn-primary:active,
            .btn-primary:not(:disabled):not(.disabled):active,
            .btn-primary:not(:disabled):not(.disabled).active {
                background-color: var(--brand-primary) !important;
                border-color: var(--brand-primary) !important;
            }

            .btn-primary:hover,
            .btn-primary:focus,
            .btn-add-cart:hover,
            a.text-primary:hover,
            a:hover .text-primary {
                background-color: var(--brand-secondary) !important;
                border-color: var(--brand-secondary) !important;
                color: #fff !important;
            }

            .text-primary,
            .link-hover__brand:hover,
            .u-header__nav-link:hover,
            .u-header-topbar__nav-link:hover,
            .ec.ec-add-to-cart,
            .ec.ec-favorites {
                color: var(--brand-primary) !important;
            }

            .border-primary,
            .border-color-1,
            .nav-tab .nav-link.active::before,
            .nav-tab .nav-link:hover::before {
                border-color: var(--brand-primary) !important;
            }

            .u-header-topbar .topbar-left a,
            .u-header-topbar .u-header-topbar__nav-link,
            .u-header-topbar .dropdown-nav-link,
            .u-header-topbar .text-gray-50 {
                color: #2f2f33 !important;
            }

            .u-header-topbar .topbar-left a,
            .u-header-topbar .u-header-topbar__nav-link {
                font-weight: 600;
            }

            .u-header-topbar .u-header-topbar__nav-link:hover,
            .u-header-topbar .dropdown-nav-link:hover,
            .u-header-topbar .topbar-left a:hover {
                color: #1f1f22 !important;
                opacity: 1;
            }

            .u-header-topbar .u-header-topbar__nav-item-border::after {
                border-color: rgba(47, 47, 51, 0.28) !important;
            }

            .u-header .form-control,
            .u-header .form-control::placeholder {
                color: #5f636b !important;
                font-weight: 600;
            }

            .bg-primary-down-lg {
                background-color: #ffffff !important;
            }

            .product-page-ncr .product-gallery-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 16px;
            }

            /* Uma só imagem: ocupa toda a largura */
            .product-page-ncr .product-gallery-grid.single-image {
                grid-template-columns: 1fr;
            }
            .product-page-ncr .product-gallery-grid.single-image .product-gallery-item {
                min-height: 420px;
            }

            .product-page-ncr .product-gallery-item {
                background: #f8f9fb;
                border: 1px solid #e7e9ef;
                border-radius: 8px;
                padding: 14px;
                min-height: 220px;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .product-page-ncr .product-gallery-item img {
                width: 100%;
                max-height: 230px;
                object-fit: contain;
                cursor: zoom-in;
            }

            /* Lightbox */
            #ncrLightbox {
                display: none;
                position: fixed;
                inset: 0;
                z-index: 9999;
                background: rgba(0,0,0,.72);
                align-items: center;
                justify-content: center;
            }
            #ncrLightbox.is-open {
                display: flex;
            }
            .ncr-lb-inner {
                background: #fff;
                border-radius: 12px;
                padding: 28px 28px 20px;
                max-width: 720px;
                width: 92vw;
                position: relative;
                box-shadow: 0 24px 64px rgba(0,0,0,.35);
            }
            .ncr-lb-close {
                position: absolute;
                top: 12px;
                right: 16px;
                background: none;
                border: none;
                font-size: 28px;
                line-height: 1;
                color: #444;
                cursor: pointer;
                z-index: 2;
            }
            .ncr-lb-close:hover { color: #000; }
            .ncr-lb-stage {
                position: relative;
                background: #f5f7fa;
                border-radius: 8px;
                display: flex;
                align-items: center;
                justify-content: center;
                min-height: 340px;
                max-height: 60vh;
                overflow: hidden;
                margin-bottom: 16px;
            }
            .ncr-lb-stage img {
                max-width: 100%;
                max-height: 58vh;
                object-fit: contain;
            }
            .ncr-lb-arrow {
                position: absolute;
                top: 50%;
                transform: translateY(-50%);
                background: rgba(255,255,255,.9);
                border: 1px solid #dce2ec;
                border-radius: 50%;
                width: 40px;
                height: 40px;
                display: flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                font-size: 18px;
                color: #333;
                transition: background .15s;
                z-index: 2;
            }
            .ncr-lb-arrow:hover { background: #fff; color: #F57C00; }
            .ncr-lb-prev { left: 10px; }
            .ncr-lb-next { right: 10px; }
            .ncr-lb-thumbs {
                display: flex;
                gap: 10px;
                justify-content: center;
            }
            .ncr-lb-thumb {
                width: 76px;
                height: 76px;
                border-radius: 6px;
                border: 2px solid #dce2ec;
                background: #f5f7fa;
                overflow: hidden;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: border-color .15s;
            }
            .ncr-lb-thumb img {
                width: 100%;
                height: 100%;
                object-fit: contain;
            }
            .ncr-lb-thumb.active {
                border-color: #0f83cf;
            }
            .ncr-lb-thumb:hover {
                border-color: #F57C00;
            }

            .product-page-ncr .ncr-product-box {
                background: #fff;
                border: 1px solid #e7e9ef;
                border-radius: 10px;
                padding: 24px;
                box-shadow: 0 6px 20px rgba(20, 34, 66, 0.04);
            }

            .product-page-ncr .ncr-brand-row {
                display: flex;
                align-items: center;
                gap: 10px;
                margin-bottom: 10px;
            }

            .product-page-ncr .ncr-brand-logo {
                height: 28px;
                max-width: 120px;
                object-fit: contain;
            }

            .product-page-ncr .ncr-brand-name {
                font-size: 12px;
                color: #5f636b;
                font-weight: 600;
            }

            .product-page-ncr .ncr-qty {
                display: inline-flex;
                align-items: center;
                border: 1px solid #cdd4df;
                border-radius: 8px;
                overflow: hidden;
                height: 44px;
            }

            .product-page-ncr .ncr-qty-btn {
                width: 40px;
                height: 42px;
                border: 0;
                background: #f5f7fa;
                color: #23324a;
                font-size: 20px;
                font-weight: 700;
                line-height: 1;
            }

            .product-page-ncr .ncr-qty-input {
                width: 44px;
                border: 0;
                text-align: center;
                font-weight: 700;
                color: #23324a;
                background: #fff;
            }

            .product-page-ncr .bundle-card,
            .product-page-ncr .seen-card,
            .product-page-ncr .bundle-summary,
            .product-page-ncr .review-panel {
                background: #fff;
                border: 1px solid #dce2ec;
                border-radius: 8px;
                padding: 16px;
            }

            .product-page-ncr .score-circle {
                width: 112px;
                height: 112px;
                border-radius: 50%;
                border: 4px solid #0f83cf;
                color: #23324a;
                font-size: 32px;
                font-weight: 700;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            /* Botões produto */
            .product-page-ncr .ncr-btn-add-cart {
                border: 2px solid #F57C00;
                color: #F57C00;
                background: #fff;
                border-radius: 6px;
                font-weight: 600;
                font-size: 14px;
                transition: background .2s, color .2s;
                text-align: center;
            }
            .product-page-ncr .ncr-btn-add-cart:hover {
                background: #F57C00;
                color: #fff;
            }
            .product-page-ncr .ncr-btn-buy {
                background: #F57C00;
                border: 2px solid #F57C00;
                color: #fff;
                border-radius: 6px;
                font-weight: 700;
                font-size: 16px;
                transition: background .2s, border-color .2s;
            }
            .product-page-ncr .ncr-btn-buy:hover {
                background: #D96A00;
                border-color: #D96A00;
                color: #fff;
            }

            /* Sidebar social */
            .product-page-ncr .ncr-social-sidebar {
                display: flex;
                flex-direction: column;
                gap: 8px;
                padding-top: 4px;
                flex-shrink: 0;
            }
            .product-page-ncr .ncr-social-btn {
                width: 44px;
                height: 44px;
                background: #fff;
                border: 1px solid #dce2ec;
                border-radius: 8px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #666;
                font-size: 15px;
                transition: border-color .2s, color .2s;
            }
            .product-page-ncr .ncr-social-btn:hover {
                border-color: #F57C00;
                color: #F57C00;
            }

            /* Toggle icon accordion */
            .product-page-ncr .ncr-toggle-icon {
                font-size: 20px;
                line-height: 1;
                color: #555;
            }
            .product-page-ncr .ncr-show-more {
                color: #F57C00;
                font-size: 13px;
                font-weight: 600;
            }

            /* Avaliações */
            .product-page-ncr .ncr-review-stars i {
                font-size: 15px;
            }
            .product-page-ncr .ncr-star-label {
                min-width: 65px;
                display: inline-block;
            }
            .product-page-ncr .ncr-stars-row i {
                font-size: 13px;
            }
            .product-page-ncr .ncr-review-link {
                color: #F57C00;
                text-decoration: none;
            }
            .product-page-ncr .ncr-review-link:hover {
                text-decoration: underline;
                color: #D96A00;
            }

            @media (max-width: 991.98px) {
                .product-page-ncr .product-gallery-grid {
                    grid-template-columns: 1fr;
                }
                .product-page-ncr .ncr-social-sidebar {
                    display: none;
                }
            }

            .promo-tile {
                min-height: 132px;
            }

            /* Seen-card hover: image swap + cart icon */
            .seen-card {
                position: relative;
                overflow: hidden;
            }
            .seen-card .seen-img-wrap {
                position: relative;
                height: 140px;
                overflow: hidden;
                margin-bottom: 12px;
            }
            .seen-card .seen-img-wrap img {
                position: absolute;
                top: 0; left: 0;
                width: 100%;
                height: 100%;
                object-fit: contain;
                transition: opacity .35s ease;
                z-index: 1;
            }
            .seen-card .seen-img-primary { opacity: 1; }
            .seen-card .seen-img-hover  { opacity: 0; }
            .seen-card:hover .seen-img-primary { opacity: 0; }
            .seen-card:hover .seen-img-hover  { opacity: 1; }
            .seen-card .seen-cart-btn {
                position: absolute;
                bottom: 8px;
                right: 8px;
                width: 34px;
                height: 34px;
                background: #F57C00;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #fff;
                font-size: 15px;
                opacity: 0;
                transform: translateY(6px);
                transition: opacity .25s, transform .25s;
                z-index: 2;
            }
            .seen-card:hover .seen-cart-btn {
                opacity: 1;
                transform: translateY(0);
            }

            /* ========= NOVOS BLOCOS ESTILO WORTEN ========= */
            /* Estrelas sob o título */
            .ncr-rating-line { display:flex; align-items:center; gap:8px; margin-bottom:14px; flex-wrap:wrap; }
            .ncr-rating-line .ncr-rating-num { font-weight:700; color:#1a1a2e; font-size:14px; }
            .ncr-rating-line .ncr-rating-stars i { color:#FFC107; font-size:14px; }
            .ncr-rating-line .ncr-rating-stars i.empty { color:#e0e0e0; }
            .ncr-rating-line .ncr-rating-link { color:#1a1a2e; font-size:13px; text-decoration:underline; }

            /* Badge "Melhor preço" */
            .ncr-badge-melhor { background:#FFD43B; color:#1a1a2e; padding:6px 12px; border-radius:6px; font-size:13px; font-weight:600; display:inline-flex; align-items:center; gap:6px; margin-top:6px; }
            .ncr-badge-melhor i { font-size:14px; }

            /* Em stock */
            .ncr-stock-line { display:flex; align-items:center; gap:6px; color:#2e7d32; font-size:13px; font-weight:600; margin-bottom:10px; }
            .ncr-stock-line i { font-size:14px; }

            /* Blocos entrega */
            .ncr-delivery-box { border:1px solid #e2e6ee; border-radius:8px; padding:14px 16px; margin-bottom:10px; }
            .ncr-delivery-head { display:flex; align-items:center; gap:10px; font-weight:700; color:#1a1a2e; font-size:14px; margin-bottom:6px; }
            .ncr-delivery-head i { color:#1a1a2e; font-size:18px; }
            .ncr-delivery-body { display:flex; justify-content:space-between; align-items:center; }
            .ncr-delivery-body .left { font-size:13px; color:#444; }
            .ncr-delivery-body .left a { color:#444; text-decoration:underline; display:block; font-size:12px; margin-top:2px; }
            .ncr-delivery-body .ncr-delivery-free { color:#2e7d32; font-weight:700; font-size:14px; }

            /* Accordion list (Características técnicas, etc) */
            .ncr-info-list { border-top:1px solid #e2e6ee; }
            .ncr-info-item { border-bottom:1px solid #e2e6ee; }
            .ncr-info-item > a { display:flex; align-items:center; padding:18px 4px; color:#1a1a2e; font-weight:700; font-size:15px; text-decoration:none; }
            .ncr-info-item > a:hover { color:#000; }
            .ncr-info-item > a .ncr-info-icon { width:28px; margin-right:12px; font-size:18px; text-align:center; color:#1a1a2e; }
            .ncr-info-item > a .ncr-info-arrow { margin-left:auto; color:#888; font-size:14px; transition:transform .25s; }
            .ncr-info-item > a[aria-expanded="true"] .ncr-info-arrow { transform:rotate(90deg); }
            .ncr-info-item .ncr-info-body { padding:0 4px 18px; color:#444; font-size:13px; line-height:1.7; }
            .ncr-info-item .ncr-info-body a { color:#444; }

            /* Reviews redesign (Worten) */
            .ncr-reviews-section { padding:30px 0; }
            .ncr-reviews-section h3 { font-weight:700; font-size:20px; color:#1a1a2e; margin-bottom:18px; }
            .ncr-reviews-section h6 { font-weight:600; font-size:13px; color:#1a1a2e; margin-bottom:6px; }
            .ncr-reviews-section .small-label { font-size:13px; color:#444; margin-bottom:14px; }
            .ncr-bar-row { display:flex; align-items:center; gap:10px; margin-bottom:6px; font-size:13px; color:#444; }
            .ncr-bar-row .label { width:80px; flex-shrink:0; }
            .ncr-bar-row .bar { flex:1; height:8px; background:#e6e6e6; border-radius:4px; overflow:hidden; }
            .ncr-bar-row .bar > span { display:block; height:100%; background:#FFC107; border-radius:4px; }
            .ncr-bar-row .count { width:30px; text-align:right; }
            .ncr-global-rating { display:flex; align-items:center; gap:14px; margin:18px 0 8px; }
            .ncr-global-rating .num { font-size:42px; font-weight:700; color:#1a1a2e; line-height:1; }
            .ncr-global-rating .stars i { color:#FFC107; font-size:14px; margin-right:1px; }
            .ncr-global-rating .stars i.empty { color:#e0e0e0; }
            .ncr-global-rating .stars a { display:block; font-size:13px; color:#1a1a2e; text-decoration:underline; margin-top:2px; }
            .ncr-recommend { font-size:13px; color:#444; margin-bottom:20px; }
            .ncr-filter-input { display:flex; align-items:center; border:1px solid #ccc; border-radius:6px; padding:10px 14px; max-width:520px; }
            .ncr-filter-input input { border:0; outline:0; flex:1; font-size:14px; color:#1a1a2e; background:transparent; }
            .ncr-filter-input i { color:#1a1a2e; }
            .ncr-filter-selects { display:flex; gap:14px; margin-top:12px; max-width:520px; }
            .ncr-filter-selects select { border:1px solid #ccc; border-radius:6px; padding:8px 12px; font-size:14px; color:#1a1a2e; background:#fff; flex:1; }
            .ncr-review-item { border-top:1px solid #e2e6ee; padding:20px 0; }
            .ncr-review-item .review-stars { color:#FFC107; font-size:13px; }
            .ncr-review-item .review-stars i.empty { color:#e0e0e0; }
            .ncr-review-item .review-author { color:#e53935; font-weight:700; font-size:14px; margin-top:6px; }
            .ncr-review-item .review-verified { display:inline-flex; align-items:center; gap:4px; font-size:11px; color:#2e7d32; font-weight:600; text-transform:uppercase; margin-top:4px; }
            .ncr-review-item .review-verified .dot { width:14px; height:14px; background:#2e7d32; color:#fff; border-radius:50%; display:inline-flex; align-items:center; justify-content:center; font-size:9px; }
            .ncr-review-item .review-time { font-size:12px; color:#888; margin-top:4px; }
            .ncr-review-item .review-text { font-size:13px; color:#333; margin-top:10px; line-height:1.5; }
            .ncr-review-item .review-actions { font-size:12px; color:#666; margin-top:10px; display:flex; align-items:center; gap:14px; }
            .ncr-review-item .review-actions a { color:#1a1a2e; text-decoration:underline; }

            /* "Descobre melhores opções" carousel + sidebar */
            .ncr-discover { padding:30px 0; }
            .ncr-discover h3 { font-weight:700; font-size:20px; color:#1a1a2e; margin-bottom:20px; }
            .ncr-discover-row { display:flex; gap:14px; align-items:stretch; }
            .ncr-discover-side { flex:0 0 200px; background:#f0f1f5; border-radius:14px; padding:24px 16px; text-align:center; display:flex; flex-direction:column; justify-content:center; align-items:center; }
            .ncr-discover-side img { max-width:140px; margin-bottom:14px; }
            .ncr-discover-side h5 { font-weight:700; font-size:16px; color:#1a1a2e; margin-bottom:8px; }
            .ncr-discover-side p { font-size:13px; color:#444; margin-bottom:0; }
            .ncr-discover-cards { flex:1; min-width:0; }
            .ncr-discover-cards .slick-slide { padding:0 6px; }
            .ncr-discover-cards .slick-prev, .ncr-discover-cards .slick-next { z-index:5; width:34px; height:34px; background:#fff !important; border-radius:50%; box-shadow:0 2px 8px rgba(0,0,0,.15); }
            .ncr-discover-cards .slick-prev { left:-12px; }
            .ncr-discover-cards .slick-next { right:-12px; }
            .ncr-discover-cards .slick-prev:before, .ncr-discover-cards .slick-next:before { color:#1a1a2e; font-family:FontAwesome; opacity:1; font-size:18px; }
            .ncr-discover-cards .slick-prev:before { content:"\f053"; }
            .ncr-discover-cards .slick-next:before { content:"\f054"; }
            @media (max-width: 767.98px) {
                .ncr-discover-row { flex-direction:column; }
                .ncr-discover-side { flex:0 0 auto; }
            }

            /* Sticky header bar (aparece ao fazer scroll) */
            .ncr-sticky-bar {
                position:fixed; top:0; left:0; right:0; z-index:1050;
                background:#fff; border-bottom:1px solid #e2e6ee; box-shadow:0 2px 8px rgba(0,0,0,.08);
                padding:10px 0; transform:translateY(-100%); transition:transform .3s ease;
            }
            .ncr-sticky-bar.is-visible { transform:translateY(0); }
            .ncr-sticky-bar .container { display:flex; align-items:center; gap:16px; }
            .ncr-sticky-bar .ncr-sticky-logo img { height:34px; }
            .ncr-sticky-bar .ncr-sticky-title { flex:1; font-weight:700; font-size:15px; color:#1a1a2e; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
            .ncr-sticky-bar .ncr-sticky-price { font-weight:700; font-size:17px; color:#1a1a2e; white-space:nowrap; }
            .ncr-sticky-bar .ncr-sticky-old { color:#888; text-decoration:line-through; font-size:13px; margin-left:6px; font-weight:400; }
            .ncr-sticky-bar .ncr-sticky-badge { background:#FFD43B; color:#1a1a2e; padding:2px 6px; border-radius:4px; font-size:11px; font-weight:700; margin-left:4px; }
            .ncr-sticky-bar .ncr-sticky-cart { background:#F57C00; color:#fff; border:0; border-radius:6px; padding:10px 18px; font-weight:700; font-size:13px; display:inline-flex; align-items:center; gap:8px; white-space:nowrap; }
            .ncr-sticky-bar .ncr-sticky-cart:hover { background:#D96A00; color:#fff; }
            @media (max-width: 767.98px) {
                .ncr-sticky-bar .ncr-sticky-logo, .ncr-sticky-bar .ncr-sticky-old, .ncr-sticky-bar .ncr-sticky-badge { display:none; }
            }

            .promo-tile .promo-copy {
                min-height: 112px;
                display: flex;
                flex-direction: column;
                justify-content: center;
            }

            .promo-tile .promo-title {
                margin-bottom: 8px;
                line-height: 1.18;
            }

            .promo-tile .link {
                margin-top: auto;
            }

            .promo-tile .link__icon-inner {
                background-color: var(--brand-primary) !important;
                border-color: var(--brand-primary) !important;
                color: #ffffff !important;
            }

            .promo-tile .link__icon-inner i {
                color: #ffffff !important;
            }

            .floating-cart {
                position: fixed;
                right: 18px;
                bottom: 78px;
                z-index: 1032;
                display: none;
            }

            .floating-cart.is-visible {
                display: block;
            }

            .floating-cart__toggle {
                width: 56px;
                height: 56px;
                border: 0;
                border-radius: 50%;
                background: var(--brand-primary);
                color: #1f1f22;
                box-shadow: 0 10px 24px rgba(0, 0, 0, 0.22);
                font-size: 22px;
                position: relative;
            }

            .floating-cart__count {
                position: absolute;
                top: -6px;
                right: -6px;
                width: 22px;
                height: 22px;
                border-radius: 50%;
                background: #1f1f22;
                color: #fff;
                font-size: 12px;
                font-weight: 700;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .cart-drawer-overlay {
                position: fixed;
                inset: 0;
                background: rgba(0, 0, 0, 0.45);
                z-index: 1040;
                opacity: 0;
                visibility: hidden;
                transition: opacity .25s ease, visibility .25s ease;
            }

            .cart-drawer-overlay.is-open {
                opacity: 1;
                visibility: visible;
            }

            .cart-drawer {
                position: fixed;
                top: 0;
                right: 0;
                width: min(92vw, 420px);
                height: 100vh;
                background: #fff;
                z-index: 1050;
                transform: translateX(100%);
                transition: transform .28s ease;
                box-shadow: -12px 0 28px rgba(0, 0, 0, 0.2);
                display: flex;
                flex-direction: column;
            }

            .cart-drawer.is-open {
                transform: translateX(0);
            }

            .cart-drawer__header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 16px 18px;
                border-bottom: 1px solid #ececec;
            }

            .cart-drawer__title {
                margin: 0;
                font-size: 26px;
                line-height: 1;
                color: #222;
            }

            .cart-drawer__close {
                border: 0;
                background: transparent;
                color: #222;
                font-size: 30px;
                line-height: 1;
                padding: 0;
                cursor: pointer;
            }

            .cart-drawer__body {
                flex: 1;
                overflow-y: auto;
                padding: 18px;
            }

            .cart-drawer__meta {
                font-size: 17px;
                color: #23262f;
                margin-top: -4px;
            }

            .cart-drawer__empty {
                min-height: calc(100vh - 140px);
                display: flex;
                align-items: center;
                justify-content: center;
                flex-direction: column;
                text-align: center;
                color: #3a3f4b;
            }

            .cart-drawer__empty-icon {
                width: 170px;
                height: 170px;
                border-radius: 50%;
                background: #0f83cf;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #fff;
                font-size: 86px;
                margin-bottom: 28px;
            }

            .cart-drawer__empty-text {
                font-size: 46px;
                line-height: 1.08;
                color: #3e4555;
                margin: 0;
            }

            @media (max-width: 575.98px) {
                .cart-drawer__empty-text {
                    font-size: 42px;
                }

                .cart-drawer__empty-icon {
                    width: 160px;
                    height: 160px;
                    font-size: 80px;
                }
            }

            .cart-drawer-open {
                overflow: hidden;
            }

            @media (max-width: 1199.98px) {
                .floating-cart,
                .floating-cart.is-visible {
                    display: none !important;
                }
            }
        </style>
    </head>

    <body>

        <!-- Sticky bar do produto (aparece ao fazer scroll) -->
        <div class="ncr-sticky-bar" id="ncrStickyBar">
            <div class="container">
                <% if (product.images && product.images[0]) { %>
                <a href="/" class="ncr-sticky-logo" style="flex-shrink:0"><img src="<%= product.images[0] %>" alt="<%= product.name %>" style="height:44px;width:44px;object-fit:contain;border-radius:4px;border:1px solid #eee"></a>
                <% } else { %>
                <a href="/" class="ncr-sticky-logo"><img src="https://cdn100ka.sysvenus.com/logo/logo-1752749442.jpg" alt="100bytes"></a>
                <% } %>
                <div class="ncr-sticky-title"><%= product.name %></div>
                <div class="ncr-sticky-price">
                    <% if (product.salePrice) { %>
                    <span style="color:#e53935"><%= product.salePrice %></span>
                    <span class="ncr-sticky-old"><%= product.basePrice %></span>
                    <% } else { %>
                    <%= product.basePrice %>
                    <% } %>
                </div>
                <a href="#" class="ncr-sticky-cart"><i class="ec ec-add-to-cart"></i> ADICIONAR AO CARRINHO</a>
            </div>
        </div>

        <%- include('partials/_header') %>

        <!-- ========== MAIN CONTENT ========== -->
                <main id="content" role="main" class="product-page-ncr">
            <div class="bg-gray-13 bg-md-transparent py-3 border-bottom">
                <div class="container">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0 bg-transparent p-0 font-size-14">
                            <li class="breadcrumb-item"><a href="index.html">Pagina inicial</a></li>
                            <% if (product.category) { %><li class="breadcrumb-item"><a href="/<%= product.categorySlug %>"><%= product.category %></a></li><% } %>
                            <li class="breadcrumb-item active" aria-current="page"><%= product.name %></li>
                        </ol>
                    </nav>
                </div>
            </div>

            <div class="container py-5">
                <div class="row">
                    <div class="col-xl-7 mb-4 mb-xl-0">
                        <div class="product-gallery-grid<%= product.images.length <= 1 ? ' single-image' : '' %>">
                            <% product.images.forEach(function(img, i) { %>
                            <div class="product-gallery-item <%= i===0 ? 'is-main' : '' %>">
                                <img src="<%= img %>" alt="<%= product.name %> - Vista <%= i+1 %>" class="img-fluid">
                            </div>
                            <% }); %>
                            <% if (product.images.length === 0) { %>
                            <div class="product-gallery-item is-main d-flex align-items-center justify-content-center bg-gray-300" style="min-height:420px">
                                <span class="text-muted">Sem imagem</span>
                            </div>
                            <% } %>
                        </div>
                    </div>

                    <div class="col-xl-5">
                        <div class="d-flex">
                            <div class="ncr-product-box flex-grow-1">
                                <% if (product.reference) { %><p class="text-gray-6 mb-1 font-size-13">Referência: <%= product.reference %></p><% } %>
                                <% if (product.brand || product.brandLogo) { %>
                                <div class="ncr-brand-row">
                                    <% if (product.brandLogo) { %>
                                    <img class="ncr-brand-logo" src="<%= product.brandLogo %>" alt="<%= product.brand || 'Marca' %>">
                                    <% } %>
                                    <% if (product.brand) { %>
                                    <span class="ncr-brand-name"><%= product.brand %></span>
                                    <% } %>
                                </div>
                                <% } %>
                                <h1 class="font-size-22 font-weight-bold text-gray-90 mb-2 line-height-1-4"><%= product.name %></h1>
                                <div class="ncr-rating-line">
                                    <span class="ncr-rating-num">0</span>
                                    <span class="ncr-rating-stars">
                                        <i class="fas fa-star empty"></i><i class="fas fa-star empty"></i><i class="fas fa-star empty"></i><i class="fas fa-star empty"></i><i class="fas fa-star empty"></i>
                                    </span>
                                    <a href="#avaliacoes" class="ncr-rating-link">(0 avaliações do produto)</a>
                                </div>
                                <% if (product.salePrice) { %>
                                <div class="mb-2">
                                    <div class="d-flex align-items-baseline flex-wrap" style="gap:10px">
                                        <span id="priceDisplay" class="font-weight-bold" style="font-size:2.4rem;color:#F57C00;letter-spacing:-0.5px"><%= product.salePrice %></span>
                                        <del class="font-size-16" style="color:#aaa"><%= product.basePrice %></del>
                                        <span class="badge badge-danger font-size-12 align-self-center">Oferta</span>
                                    </div>
                                    <p class="font-size-12 mb-0" style="color:#aaa">Preço unitário &middot; IVA incluído</p>
                                    <span class="ncr-badge-melhor"><i class="fas fa-info-circle"></i> Melhor preço - últimos 30 dias</span>
                                </div>
                                <% } else { %>
                                <div class="mb-2">
                                    <div class="d-flex align-items-baseline">
                                        <span id="priceDisplay" class="font-weight-bold" style="font-size:2.4rem;color:#1a1a2e;letter-spacing:-0.5px"><%= product.basePrice %></span>
                                    </div>
                                    <p class="font-size-12 mb-0" style="color:#aaa">Preço unitário &middot; IVA incluído</p>
                                </div>
                                <% } %>
                                <% var inStock = !product.trackStock || (product.stock != null && product.stock > 0); %>
                                <% if (inStock) { %>
                                <div class="ncr-stock-line"><i class="fas fa-check-circle"></i> Em stock<% if (product.trackStock && product.stock != null) { %> &middot; <%= product.stock %> unidades<% } %></div>
                                <% } else { %>
                                <div class="ncr-stock-line" style="color:#c62828"><i class="fas fa-times-circle"></i> Sem stock</div>
                                <% } %>
                                <div id="totalPriceWrap" class="mb-3 p-2 rounded d-none" style="background:#fff8f0;border:1px solid #ffe0b2">
                                    <span class="font-size-13" style="color:#888">Total: </span>
                                    <span id="totalPrice" class="font-weight-bold font-size-18" style="color:#F57C00"></span>
                                </div>

                                <div class="d-flex align-items-center mb-3">
                                    <div class="ncr-qty mr-3" id="qtyWidget">
                                        <button type="button" class="ncr-qty-btn" id="qtyMinus">-</button>
                                        <input type="text" value="1" readonly class="ncr-qty-input" id="qtyInput">
                                        <button type="button" class="ncr-qty-btn" id="qtyPlus">+</button>
                                    </div>
                                    <a href="#" class="btn ncr-btn-add-cart px-3 py-2 flex-grow-1">Adicionar ao carrinho</a>
                                </div>

                                <a href="#" class="btn ncr-btn-buy btn-block py-3 mb-3 font-weight-bold">Finalizar compra</a>

                                <div class="ncr-delivery-box">
                                    <div class="ncr-delivery-head"><i class="far fa-building"></i> Levanta na loja</div>
                                    <div class="ncr-delivery-body">
                                        <div class="left">Em <strong>15 minutos</strong><a href="#" id="btnVerDisponibilidadeLoja" onclick="abrirModalLoja(event)">Ver disponibilidade</a></div>
                                        <span class="ncr-delivery-free">Grátis</span>
                                    </div>
                                </div>
                            </div>
                            <div class="ncr-social-sidebar ml-2">
                                <a href="https://www.facebook.com/p/100bytes-100063935954143/" target="_blank" rel="noopener" class="ncr-social-btn" title="Partilhar no Facebook"><i class="fab fa-facebook-f"></i></a>
                                <a href="#" class="ncr-social-btn" title="Adicionar aos favoritos"><i class="far fa-heart"></i></a>
                                <a href="#" class="ncr-social-btn" title="Partilhar" id="btnNativeShare" onclick="nativeShare(event)"><i class="fas fa-share-alt"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Lista informativa: Descrição / Características técnicas / Ver stock / Comentários -->
            <div class="container pb-5">
                <div class="ncr-info-list">
                    <div class="ncr-info-item">
                        <a data-toggle="collapse" href="#info-desc" role="button" aria-expanded="true" aria-controls="info-desc">
                            <span class="ncr-info-icon"><i class="far fa-file-alt"></i></span>
                            Descrição
                            <span class="ncr-info-arrow"><i class="fas fa-chevron-right"></i></span>
                        </a>
                        <div class="collapse show" id="info-desc">
                            <div class="ncr-info-body" style="white-space:normal;font-size:13px;line-height:1.7;color:#444"><%= product.description || 'Sem descrição disponível.' %></div>
                        </div>
                    </div>
                    <div class="ncr-info-item">
                        <a data-toggle="collapse" href="#info-ficha" role="button" aria-expanded="false" aria-controls="info-ficha" class="collapsed">
                            <span class="ncr-info-icon"><i class="fas fa-microchip"></i></span>
                            Características técnicas
                            <span class="ncr-info-arrow"><i class="fas fa-chevron-right"></i></span>
                        </a>
                        <div class="collapse" id="info-ficha">
                            <div class="ncr-info-body">
                                <% if (product.sheetUrl) { %>
                                <a href="<%= product.sheetUrl %>" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm"><i class="far fa-file-pdf mr-1"></i> Descarregar ficha técnica</a>
                                <% } else { %>
                                Sem ficha técnica disponível.
                                <% } %>
                            </div>
                        </div>
                    </div>
                    <div class="ncr-info-item">
                        <a data-toggle="collapse" href="#info-stock" role="button" aria-expanded="false" aria-controls="info-stock" class="collapsed" id="stockAccordionToggle">
                            <span class="ncr-info-icon"><i class="far fa-building"></i></span>
                            Ver stock em loja
                            <span class="ncr-info-arrow"><i class="fas fa-chevron-right"></i></span>
                        </a>
                        <div class="collapse" id="info-stock">
                            <div class="ncr-info-body" id="storeStockBody">
                                <div id="storeStockLoading" class="text-muted font-size-13">A carregar disponibilidade...</div>
                                <div id="storeStockList" style="display:none"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="container pb-7">
                <h3 class="section-title mb-4">Descobre melhores opções</h3>
                <% if (related && related.length > 0) { %>
                <div class="row">
                    <% related.forEach(function(r) { %>
                    <div class="col-6 col-md-4 col-lg-2 mb-3">
                        <a href="/<%= r.categorySlug %>/<%= r.urlKey %>" class="seen-card h-100 d-block text-decoration-none text-reset">
                            <% if (r.image) { %>
                            <div class="seen-img-wrap position-relative">
                                <img class="seen-img-primary" src="<%= r.image %>" alt="<%= r.name %>">
                                <img class="seen-img-hover" src="<%= r.image2 || r.image %>" alt="<%= r.name %>">
                                <span class="seen-cart-btn"><i class="ec ec-add-to-cart"></i></span>
                                <% if (r.discountPct) { %><span style="position:absolute;top:6px;left:6px;background:#ffc107;color:#212529;font-size:10px;font-weight:700;padding:2px 7px;border-radius:20px;z-index:2;line-height:1.5;pointer-events:none">-<%= r.discountPct %>%</span><% } %>
                                <% if (r.isNew) { %><span style="position:absolute;top:6px;right:6px;background:#28a745;color:#fff;font-size:10px;font-weight:700;padding:2px 7px;border-radius:20px;z-index:2;line-height:1.5;pointer-events:none">NOVO</span><% } else if (r.lowStock) { %><span style="position:absolute;top:6px;right:6px;background:#fd7e14;color:#fff;font-size:10px;font-weight:600;padding:2px 7px;border-radius:20px;z-index:2;line-height:1.5;pointer-events:none">Aproveite agora</span><% } %>
                            </div>
                            <% } else { %>
                            <div class="bg-gray-300 d-flex align-items-center justify-content-center mb-3" style="height:140px;color:#aaa;font-size:13px">Sem imagem</div>
                            <% } %>
                            <h6 class="font-size-13 mb-2 text-blue"><%= r.name %></h6>
                            <% if (r.salePrice) { %>
                            <div class="font-size-18 font-weight-bold text-red"><%= r.salePrice %></div>
                            <del class="font-size-13 text-gray-6"><%= r.basePrice %></del>
                            <% } else { %>
                            <div class="font-size-18 font-weight-bold text-gray-90"><%= r.basePrice %></div>
                            <% } %>
                        </a>
                    </div>
                    <% }) %>
                </div>
                <% } else { %>
                <p class="text-gray-6 font-size-14">Sem produtos relacionados.</p>
                <% } %>
            </div>
        </main>
