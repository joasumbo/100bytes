generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  photoKey     String?

  @@map("admin_users")
}

model Brand {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  country   String?
  logoKey   String?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@map("brands")
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  imageKey    String?
  parentId    String?
  active      Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  parent      Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[] @relation("SubCategories")
  products    Product[]

  @@map("categories")
}

model Product {
  id             String       @id @default(cuid())
  reference      String       @unique
  name           String
  slug           String       @unique
  description    String?
  imageKeys      String[]
  sheetKey       String?
  costPrice      Float?
  basePrice      Float        @default(0)
  hasIva         Boolean      @default(true)
  ivaRate        Float        @default(14)
  hasIec         Boolean      @default(false)
  iecRate        Float        @default(0)
  salePrice      Float?
  trackStock     Boolean      @default(true)
  stock          Int          @default(0)
  stockAlert     Int          @default(5)
  categoryId     String?
  brandId        String?
  active         Boolean      @default(true)
  featured       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  linkedInBundle BundleItem[] @relation("BundleLinked")
  bundleItems    BundleItem[] @relation("BundleParent")
  brand          Brand?       @relation(fields: [brandId], references: [id])
  category       Category?    @relation(fields: [categoryId], references: [id])
  storeStocks    StoreStock[]

  @@map("products")
}

model BundleItem {
  id          String   @id @default(cuid())
  parentId    String
  linkedId    String?
  name        String
  price       Float
  discountPct Float    @default(0)
  sortOrder   Int      @default(0)
  linked      Product? @relation("BundleLinked", fields: [linkedId], references: [id])
  parent      Product  @relation("BundleParent", fields: [parentId], references: [id], onDelete: Cascade)

  @@map("bundle_items")
}

model Store {
  id          String       @id @default(cuid())
  name        String
  address     String
  phone       String?
  lat         Float?
  lng         Float?
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  storeStocks StoreStock[]

  @@map("stores")
}

model StoreStock {
  id        String   @id @default(cuid())
  productId String
  storeId   String
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([productId, storeId])
  @@map("store_stocks")
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("site_content")
}

model Customer {
  id           String     @id @default(cuid())
  name         String
  phone        String?
  email        String     @unique
  passwordHash String
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  favorites    Favorite[]

  @@map("customers")
}

model Favorite {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  String
  createdAt  DateTime @default(now())

  @@unique([customerId, productId])
  @@map("favorites")
}
