generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  active       Boolean  @default(true)
  photoKey     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}

model Brand {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  country   String?
  logoKey   String?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@map("brands")
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  imageKey    String?
  parentId    String?
  parent      Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[] @relation("SubCategories")
  products    Product[]
  active      Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("categories")
}

model Product {
  id          String   @id @default(cuid())
  reference   String   @unique
  name        String
  slug        String   @unique
  description String?

  imageKeys   String[]
  sheetKey    String?

  costPrice   Float?
  basePrice   Float    @default(0)
  hasIva      Boolean  @default(true)
  ivaRate     Float    @default(14)
  hasIec      Boolean  @default(false)
  iecRate     Float    @default(0)
  salePrice   Float?

  trackStock  Boolean  @default(true)
  stock       Int      @default(0)
  stockAlert  Int      @default(5)

  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  brandId     String?
  brand       Brand?    @relation(fields: [brandId], references: [id])

  active      Boolean  @default(true)
  featured    Boolean  @default(false)

  bundleItems    BundleItem[] @relation("BundleParent")
  linkedInBundle BundleItem[] @relation("BundleLinked")
  storeStocks    StoreStock[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("products")
}

model BundleItem {
  id          String  @id @default(cuid())
  parentId    String
  parent      Product @relation("BundleParent", fields: [parentId], references: [id], onDelete: Cascade)
  linkedId    String?
  linked      Product? @relation("BundleLinked", fields: [linkedId], references: [id], onDelete: SetNull)
  name        String
  price       Float
  discountPct Float   @default(0)
  sortOrder   Int     @default(0)

  @@map("bundle_items")
}

model Store {
  id          String       @id @default(cuid())
  name        String
  address     String
  phone       String?
  lat         Float?
  lng         Float?
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  storeStocks StoreStock[]

  @@map("stores")
}

model StoreStock {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([productId, storeId])
  @@map("store_stocks")
}


